rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Brochure: anyone can read
    match /brochure/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Services/Portfolio images: anyone can read, only admin can write
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
